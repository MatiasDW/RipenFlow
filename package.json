{
  "name": "ripenflow-madrid",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "packageManager": "bun@1.3.12",
  "scripts": {
    "dev": "$HOME/.bun/bin/bunx --bun vite",
    "build": "$HOME/.bun/bin/bunx --bun tsc -b && $HOME/.bun/bin/bunx --bun vite build",
    "preview": "$HOME/.bun/bin/bunx --bun vite preview",
    "lint": "node scripts/run-biome.mjs check .",
    "format": "node scripts/run-biome.mjs format --write .",
    "db:generate": "drizzle-kit generate",
    "db:migrate": "drizzle-kit migrate",
    "db:studio": "drizzle-kit studio"
  },
  "dependencies": {
    "@tanstack/react-query": "^5.99.1",
    "@tanstack/react-query-devtools": "^5.99.1",
    "@tanstack/react-router": "^1.168.23",
    "@tanstack/router-devtools": "^1.166.13",
    "drizzle-orm": "^0.45.2",
    "postgres": "^3.4.9",
    "react": "^19.2.5",
    "react-dom": "^19.2.5",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.4.12",
    "@types/node": "^24.12.2",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "4.7.0",
    "dotenv": "^17.4.2",
    "drizzle-kit": "^0.31.10",
    "typescript": "~6.0.3",
    "vite": "6.4.1"
  }
}
